# MLflow et modèles
# ================================
mlruns/
mlartifacts/
--default-artifact-root/
mlflow.log
LOGFILE_ML

# Ignorer uniquement les modèles lourds, pas les scripts Python
scripts/models/*.pkl
scripts/models/*.bin
scripts/models/*.pt
scripts/models/*.joblib
scripts/models/*.h5
scripts/models/*.sav
scripts/models/*.onnx

# Garder les scripts Python
!scripts/**/*.py

