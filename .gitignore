# ============================================
# ENVIRONNEMENTS PYTHON
# ============================================
cde_env/
cde_fastapi_env/
cde_streamlit_env/
.venv/
venv/
*.egg-info/
__pycache__/
*.pyc
*.pyo
*.pyd

# ============================================
# DONNÉES & FICHIERS LOURDS
# ============================================
# Ignorer la plupart des dossiers data
data/trustpilot/
data/processed/resources/
data/processed/export_*.csv
data/processed/stats_*.csv
data/processed/resultats_*.csv
data/report/

# Mais GARDER certains dossiers
!data/wikipedia/
!data/processed/.keep
!data/model/.keep
!data/export/

# ML models (fichiers binaires lourds)
data/model/*.pkl
data/model/*.joblib
data/model/*.pt
data/model/*.bin
data/model/*.h5
data/model/*.onnx

# ============================================
# DOCKER
# ============================================
docker/overlay2/
docker-data/
docker/volumes/
docker/_data/

# Garder les Dockerfile & configs
!docker/*.Dockerfile
!docker/Dockerfile
!docker-compose*.yml

# ============================================
# MLflow
# ============================================
mlruns/
mlartifacts/
mlflow.log

# ============================================
# MODELS (scripts gardés, poids ignorés)
scripts/models/*.pkl
scripts/models/*.joblib
scripts/models/*.pt
scripts/models/*.bin
scripts/models/*.onnx
scripts/models/*.h5
scripts/models/*.sav

# Garder le code Python
!scripts/**/*.py

